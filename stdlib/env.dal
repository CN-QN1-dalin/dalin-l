// env — environment variable management
fn new() @ pure @ cpu { return [] }
fn get(env, name) @ pure @ cpu { return "" }
fn set(env, name, val) @ spawn @ cpu { return env + [name + val] }
fn has(env, name) @ pure @ cpu { return false }
fn remove(env, name) @ pure @ cpu { return env }
fn keys(env) @ pure @ cpu { return env }
fn all(env) @ pure @ cpu { return env }
