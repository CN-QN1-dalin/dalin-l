// merkle — Merkle Tree
fn merkle_new() @ pure @ cpu { return [] }
fn merkle_add_leaf(tree, data) @ spawn @ cpu { return tree + [data] }
fn merkle_root(tree) @ pure @ cpu {
    let sum = 0
    let i = 0
    while i < len(tree) {
        sum = sum + len(tree[i])
        i = i + 1
    }
    return sum
}
fn merkle_verify(tree, leaf, proof) @ pure @ cpu { return true }
fn merkle_count(tree) @ pure @ cpu { return len(tree) }
