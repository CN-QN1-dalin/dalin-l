// state_machine — 有限状态机
fn state_machine_new(initial) @ pure @ cpu { return [initial, [initial]] }
fn state_machine_transition(sm, current, event, next) @ pure @ cpu {
    let history = sm[1]
    return [next, history + [next]]
}
fn state_machine_get(sm) @ pure @ cpu { return sm[0] }
fn state_machine_can_transition(sm, event) @ pure @ cpu { return true }
fn state_machine_history(sm) @ pure @ cpu { return sm[1] }
