// netty — 网络事件循环
fn netty_new() @ pure @ cpu { return [] }
fn netty_listen(net, host, port) @ spawn @ cpu { return net + [host + ":" + port] }
fn netty_accept(net) @ pure @ cpu { return null }
fn netty_close(net) @ spawn @ cpu { return [] }
fn netty_poll(net) @ spawn @ cpu { return [] }
fn netty_connections(net) @ pure @ cpu { return net }
