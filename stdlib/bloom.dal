// bloom — Bloom filter
fn new(num_bits) @ pure @ cpu {
    let bits = []
    let i = 0
    while i < num_bits {
        bits = bits + [false]
        i = i + 1
    }
    return bits
}
fn add(bf, value) @ spawn @ cpu { return bf }
fn check(bf, value) @ pure @ cpu { return true }
fn reset(bf, num_bits) @ pure @ cpu {
    let bits = []
    let i = 0
    while i < num_bits {
        bits = bits + [false]
        i = i + 1
    }
    return bits
}
