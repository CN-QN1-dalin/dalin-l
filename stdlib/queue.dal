// Dalin L 标准库 — Queue (队列)
fn queue_new() @ pure @ cpu { return [] }

fn queue_push(q, val) @ spawn @ cpu {
    return q + [val]
}

fn queue_pop(q) @ spawn @ cpu {
    if len(q) == 0 {
        return [q, null]
    }
    let val = q[0]
    let new_q = q[1:]
    return [new_q, val]
}

fn queue_peek(q) @ pure @ cpu {
    if len(q) == 0 { return null }
    return q[0]
}

fn queue_len(q) @ pure @ cpu { return len(q) }

fn queue_empty(q) @ pure @ cpu { return len(q) == 0 }
