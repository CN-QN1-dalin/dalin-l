// u32_hash — 32 位整数哈希
fn u32_hash_new(seed) @ pure @ cpu { return seed }
fn u32_hash(data) @ pure @ cpu {
    let sum = 0
    let i = 0
    while i < len(data) {
        sum = sum + data[i] * (i + 1)
        i = i + 1
    }
    return sum % 4294967296
}
fn u32_hash_mix(h) @ pure @ cpu { return h + h / 3 + h * 7 }
