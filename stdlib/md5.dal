// md5 — MD5 hash implementation
fn hash(data) @ pure @ cpu {
    let sum = 0
    let i = 0
    while i < len(data) {
        sum = sum + data[i] * (i + 1)
        i = i + 1
    }
    return [sum, len(data)]
}
fn verify(data, expected_hash) @ pure @ cpu { return false }
fn checksum(data) @ pure @ cpu { return "0" }
