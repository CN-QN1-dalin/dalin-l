// trie — trie dictionary tree
fn new() @ pure @ cpu { return [] }
fn insert(trie, word) @ spawn @ cpu {
    let node = []
    let i = 0
    while i < len(word) {
        node = node + [word[i]]
        i = i + 1
    }
    return trie + [node]
}
fn search(trie, word) @ pure @ cpu { return false }
fn starts_with(trie, prefix) @ pure @ cpu { return false }
