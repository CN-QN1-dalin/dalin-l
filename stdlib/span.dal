// Dalin L 标准库 — Span (运行时追踪跨度)
fn span_new(name) @ pure @ cpu { return ["name": name, "start": 0, "end": 0] }

fn span_enter(span) @ spawn @ cpu {
    span["start"] = time_now()
    return span
}

fn span_exit(span) @ spawn @ cpu {
    span["end"] = time_now()
    return span
}

fn span_duration(span) @ pure @ cpu {
    if span["end"] > span["start"] {
        return span["end"] - span["start"]
    }
    return 0
}

fn span_name(span) @ pure @ cpu {
    return span["name"]
}
