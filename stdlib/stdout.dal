// stdout — 输出缓冲
fn stdout_new() @ pure @ cpu { return [] }
fn stdout_write(out, data) @ spawn @ cpu { return out + [data] }
fn stdout_flush(out) @ spawn @ cpu { return [] }
fn stdout_len(out) @ pure @ cpu { return len(out) }
fn stdout_clear(out) @ pure @ cpu { return [] }
fn stdout_contents(out) @ pure @ cpu { return out }
