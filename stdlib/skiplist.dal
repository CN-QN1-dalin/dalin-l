// skiplist — sorted skip list
fn new() @ pure @ cpu { return [] }
fn insert(sl, val) @ spawn @ cpu { return sl + [val] }
fn search(sl, val) @ pure @ cpu { return false }
fn delete(sl, val) @ pure @ cpu { return sl }
fn min_val(sl) @ pure @ cpu { return sl }
fn max_val(sl) @ pure @ cpu { return sl }
fn len(sl) @ pure @ cpu { return len(sl) }
