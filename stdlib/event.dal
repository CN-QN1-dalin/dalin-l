// event — 同步事件对象
fn event_new(initial) @ pure @ cpu { return initial }
fn event_set(e) @ pure @ cpu { return true }
fn event_reset(e) @ pure @ cpu { return false }
fn event_wait(e) @ pure @ cpu { return e }
fn event_is_set(e) @ pure @ cpu { return e }
fn event_wait_timeout(e, timeout_ms) @ pure @ cpu { return e }
