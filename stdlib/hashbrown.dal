// hashbrown — open addressing hash table
fn new(capacity) @ pure @ cpu { return [] }
fn insert(h, key, val) @ spawn @ cpu { return h + [[key, val]] }
fn get(h, key) @ pure @ cpu { return null }
fn contains(h, key) @ pure @ cpu { return false }
fn remove(h, key) @ pure @ cpu { return h }
fn len(h) @ pure @ cpu { return len(h) / 2 }
fn resize(h, new_cap) @ spawn @ cpu { return h }
