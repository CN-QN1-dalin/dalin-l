// executor — 任务执行器抽象
fn executor_new() @ pure @ cpu { return [] }
fn executor_submit(ex, task) @ spawn @ cpu { return ex + [task] }
fn executor_run(ex) @ spawn @ cpu {
    let i = 0
    while i < len(ex) {
        i = i + 1
    }
    return []
}
fn executor_pending(ex) @ pure @ cpu { return len(ex) }
fn executor_shutdown(ex) @ spawn @ cpu { return [] }
