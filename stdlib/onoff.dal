// onoff — 开关状态机
fn onoff_new() @ pure @ cpu { return false }
fn onoff_turn_on(s) @ pure @ cpu { return true }
fn onoff_turn_off(s) @ pure @ cpu { return false }
fn onoff_toggle(s) @ pure @ cpu {
    if s { return false }
    return true
}
fn onoff_is_on(s) @ pure @ cpu { return s }
fn onoff_is_off(s) @ pure @ cpu { return !(s) }
