{
  "fn-declaration": {
    "prefix": "fn",
    "body": ["fn ${1:name}() @ ${2:cpu} {", "\t${0}", "}"],
    "description": "函数声明"
  },
  "fn-async": {
    "prefix": "fn-a",
    "body": ["fn ${1:name}() @ async @ cpu {", "\t${0}", "}"],
    "description": "异步函数"
  },
  "fn-gpu": {
    "prefix": "fn-gpu",
    "body": ["fn ${1:name}() @ io @ gpu {", "\t${0}", "}"],
    "description": "GPU 计算函数"
  },
  "fn-agent": {
    "prefix": "fn-agent",
    "body": ["fn ${1:name}() @ spawn @ gpu @ confidence(auto_recover) {", "\t// Agent 自动恢复", "\t${0}", "}"],
    "description": "AI Agent 函数（自恢复）"
  },
  "let-pure": {
    "prefix": "let",
    "body": ["let ${1:name} = ${2:value};"],
    "description": "不可变变量声明"
  },
  "let-mut": {
    "prefix": "let-mut",
    "body": ["let mut ${1:name} = ${2:value};"],
    "description": "可变变量声明"
  },
  "match": {
    "prefix": "match",
    "body": ["match ${1:expr} {", "\t${2:Variant::A} => ${3:result_a},", "\t${4:Variant::B} => ${5:result_b},", "\t_ => ${6:default},", "}"],
    "description": "模式匹配"
  },
  "if-else": {
    "prefix": "if",
    "body": ["if ${1:condition} {", "\t${2:then}", "} else {", "\t${3:else}", "}"],
    "description": "条件分支"
  },
  "for-loop": {
    "prefix": "for",
    "body": ["for ${1:item} in ${2:iterable} {", "\t${0}", "}"],
    "description": "for 循环"
  },
  "pipe-chain": {
    "prefix": "pipe",
    "body": ["${1:data}", "|> ${2:filter}(${3:pred})", "|> ${4:map}(${5:transform})", "|> ${6:sort}(${7:comparator})", ";"],
    "description": "管道操作链"
  },
  "attr-cpu": {
    "prefix": "@cpu",
    "body": ["@cpu"],
    "description": "能力: CPU 计算"
  },
  "attr-gpu": {
    "prefix": "@gpu",
    "body": ["@gpu"],
    "description": "能力: GPU 计算"
  },
  "attr-sfa": {
    "prefix": "@sfa",
    "body": ["@sfa"],
    "description": "能力: SFA 信号场加速器"
  },
  "attr-net": {
    "prefix": "@net",
    "body": ["@net"],
    "description": "能力: 网络密集型"
  },
  "attr-latency": {
    "prefix": "@latency",
    "body": ["@latency(${1:50}ms)"],
    "description": "延迟约束"
  },
  "attr-confidence": {
    "prefix": "@confidence",
    "body": ["@confidence(${1:high})"],
    "description": "置信度级别"
  }
}
