// Dalin L 3.0 — Cognitive Program Example
// Demonstrates cognitive annotations working end-to-end
//
// Run with:
//   dalin run examples/cognitive.dal --gov=execute
//   dalin profile examples/cognitive.dal --gov=execute --confidence=verified

// @proven — mathematically proven function, unconditional fast path
fn factorial(n) @ pure @ cpu @ proven {
    if n <= 1 { return 1 }
    return n * factorial(n - 1)
}

// @generated — LLM-generated code, guarded at runtime
fn sort_data(data) @ pure @ cpu @ generated {
    // Bubble sort as placeholder (real @llm would generate this)
    let n = len(data)
    let i = 0
    while i < n {
        let j = 0
        while j < n - i - 1 {
            if data[j] > data[j + 1] {
                let temp = data[j]
                data[j] = data[j + 1]
                data[j + 1] = temp
            }
            j = j + 1
        }
        i = i + 1
    }
    return data
}

// @gov(approve) — requires approval governance level to execute
fn delete_file(path) @ io @ cpu @ gov(approve) {
    println("Deleting: " + path)
    return true
}

// @cognitive_loop(perceive) — runs in perceive phase only
fn read_sensor(id) @ io @ cpu @ perceive {
    println("Reading sensor: " + id)
    return 42
}

// @cognitive_loop(act) — runs in act phase only
fn execute_action(cmd) @ io @ cpu @ act {
    println("Executing: " + cmd)
    return true
}

// @latency(50ms) — time-constrained function
fn fast_compute(x) @ pure @ cpu @ latency(50ms) {
    return x * x + 2 * x + 1
}

// Main: orchestrates the cognitive pipeline
fn main() {
    // Phase-annotated calls are checked by the CognitiveLoopMachine
    let sensor_val = read_sensor("temperature")  // @perceive
    let result = fast_compute(sensor_val)         // no cognitive loop — always allowed
    
    // Confidence-gated call
    let fact_5 = factorial(5)                     // @proven — fast path
    println("5! = " + fact_5)
    
    // Governance-gated call (will fail if --gov < approve)
    // delete_file("test.txt")                    // @gov(approve)
    
    // Generated code (will fail if --confidence < generated)
    // let sorted = sort_data([3, 1, 4, 1, 5])
    
    // Act phase call
    execute_action("deploy")                      // @act
}
